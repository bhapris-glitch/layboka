node_modules/
.pnpm-store/
.npm/
.yarn/
.yarn/cache/
.yarn/unplugged/
.yarn/build-state.yml
.yarn/install-state.gz

# ----------------------------
# Build Output
# ----------------------------
.next/
out/
dist/
build/
coverage/
.turbo/

# ----------------------------
# Logs
# ----------------------------
logs/
*.log
npm-debug.log*
pnpm-debug.log*
yarn-debug.log*
yarn-error.log*

# ----------------------------
# Environment Files
# ----------------------------
.env
.env.*
!.env.example

# ----------------------------
# Operating System Files
# ----------------------------
.DS_Store
Thumbs.db
Desktop.ini

# ----------------------------
# IDE
# ----------------------------
.vscode/
.idea/
*.iml

# ----------------------------
# Temporary Files
# ----------------------------
tmp/
temp/
.cache/
.eslintcache

# ----------------------------
# TypeScript
# ----------------------------
*.tsbuildinfo

# ----------------------------
# Testing
# ----------------------------
.nyc_output/
playwright-report/
test-results/

# ----------------------------
# Local Database
# ----------------------------
*.sqlite
*.sqlite3

# ----------------------------
# Uploads
# ----------------------------
uploads/
storage/
public/uploads/

# ----------------------------
# Certificates
# ----------------------------
*.pem
*.key
*.crt

# ----------------------------
# Docker
# ----------------------------
docker-data/

# ----------------------------
# Vercel
# ----------------------------
.vercel/

# ----------------------------
# Railway
# ----------------------------
.railway/

# ----------------------------
# MongoDB
# ----------------------------
mongodb-data/

# ----------------------------
# Redis
# ----------------------------
redis-data/

# ----------------------------
# Backup Files
# ----------------------------
backup/
backups/
*.bak
*.old

# ----------------------------
# Mac Resource Files
# ----------------------------
.AppleDouble
.LSOverride

# ----------------------------
# Linux
# ----------------------------
*~

# ----------------------------
# Miscellaneous
# ----------------------------
*.swp
*.swo
*.seed
*.pid
*.pid.lock

# ----------------------------
# Generated AI Files
# ----------------------------
ai-cache/
generated/
exports/

# ----------------------------
# Chatbot Build Files
# ----------------------------
packages/chatbot-sdk/dist/
packages/chatbot-sdk/build/

# ----------------------------
# Next.js Cache
# ----------------------------
apps/web/.next/
apps/web/out/

# ----------------------------
# Express Build
# ----------------------------
apps/api/dist/

# ----------------------------
# Turbo Cache
# ----------------------------
.turbo/

# ----------------------------
# Keep Empty Folders
