# ======================================================
# LAYBOKA
# Production .gitignore
# ======================================================

# -------------------------
# Dependencies
# -------------------------
node_modules/
.pnpm-store/
.pnp/
.pnp.js

# -------------------------
# Build Output
# -------------------------
.next/
dist/
build/
coverage/
out/
.turbo/

# -------------------------
# Logs
# -------------------------
logs/
*.log
npm-debug.log*
pnpm-debug.log*
yarn-debug.log*
yarn-error.log*

# -------------------------
# Environment Variables
# -------------------------
.env
.env.*
!.env.example

# -------------------------
# Operating System
# -------------------------
.DS_Store
Thumbs.db
desktop.ini

# -------------------------
# IDE
# -------------------------
.vscode/
.idea/
*.swp
*.swo

# -------------------------
# Cache
# -------------------------
.cache/
.parcel-cache/
.eslintcache

# -------------------------
# Temporary Files
# -------------------------
tmp/
temp/

# -------------------------
# Uploads
# -------------------------
apps/api/uploads/*
!apps/api/uploads/.gitkeep

# -------------------------
# Generated Files
# -------------------------
*.tsbuildinfo

# -------------------------
# Testing
# -------------------------
coverage/
.nyc_output/

# -------------------------
# Database
# -------------------------
mongodb-data/
redis-data/

# -------------------------
# Docker
# -------------------------
docker-data/

# -------------------------
# Certificates
# -------------------------
*.pem
*.key
*.crt

# -------------------------
# Vercel
# -------------------------
.vercel/

# -------------------------
# Railway
# -------------------------
.railway/

# -------------------------
# Local SQLite
# -------------------------
*.sqlite
*.sqlite3

# -------------------------
# Misc
# -------------------------
*.seed
*.pid
*.pid.lock

# -------------------------
# Keep Empty Directories
# -------------------------
!**/.gitkeep
