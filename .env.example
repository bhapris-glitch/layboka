# =====================================================
# LAYBOKA AI SALES EXECUTIVE
# Production Environment Template
# =====================================================

# -----------------------------------------------------
# APPLICATION
# -----------------------------------------------------
NODE_ENV=development
PORT=5000
APP_NAME=Layboka
APP_URL=http://localhost:3000
API_URL=http://localhost:5000

# -----------------------------------------------------
# FRONTEND
# -----------------------------------------------------
NEXT_PUBLIC_APP_NAME=Layboka
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_API_URL=http://localhost:5000
NEXT_PUBLIC_BRAND_COLOR=#FF3B2F
NEXT_PUBLIC_BACKGROUND_COLOR=#1E3928

# -----------------------------------------------------
# JWT
# -----------------------------------------------------
JWT_SECRET=CHANGE_TO_A_LONG_RANDOM_SECRET
JWT_EXPIRES_IN=7d

# -----------------------------------------------------
# SESSION
# -----------------------------------------------------
SESSION_SECRET=CHANGE_TO_ANOTHER_RANDOM_SECRET

# -----------------------------------------------------
# MONGODB
# -----------------------------------------------------
MONGODB_URI=mongodb+srv://USERNAME:PASSWORD@cluster.mongodb.net/layboka

# -----------------------------------------------------
# REDIS
# -----------------------------------------------------
REDIS_URL=redis://localhost:6379

# -----------------------------------------------------
# OPENAI
# -----------------------------------------------------
OPENAI_API_KEY=sk-your-openai-api-key

# Default Models
OPENAI_STARTER_MODEL=gpt-4o-mini
OPENAI_GROWTH_MODEL=gpt-4o-mini
OPENAI_PREMIUM_MODEL=gpt-5
OPENAI_ENTERPRISE_MODEL=gpt-5

# -----------------------------------------------------
# SHOPIFY
# -----------------------------------------------------
SHOPIFY_API_KEY=
SHOPIFY_API_SECRET=
SHOPIFY_SCOPES=read_products,write_script_tags,read_orders,write_orders,read_customers,write_customers
SHOPIFY_APP_URL=https://api.layboka.com
SHOPIFY_WEBHOOK_SECRET=

# -----------------------------------------------------
# STRIPE
# -----------------------------------------------------
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=

# -----------------------------------------------------
# EMAIL (SMTP)
# -----------------------------------------------------
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM="Layboka <support@layboka.com>"

# -----------------------------------------------------
# CLOUDINARY
# -----------------------------------------------------
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# -----------------------------------------------------
# GOOGLE RECAPTCHA
# -----------------------------------------------------
RECAPTCHA_SITE_KEY=
RECAPTCHA_SECRET_KEY=

# -----------------------------------------------------
# ANALYTICS
# -----------------------------------------------------
GOOGLE_ANALYTICS_ID=
META_PIXEL_ID=

# -----------------------------------------------------
# CORS
# -----------------------------------------------------
CORS_ORIGIN=http://localhost:3000

# -----------------------------------------------------
# RATE LIMIT
# -----------------------------------------------------
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=100

# -----------------------------------------------------
# FILE UPLOADS
# -----------------------------------------------------
MAX_UPLOAD_SIZE=10485760

# -----------------------------------------------------
# LOGGING
# -----------------------------------------------------
LOG_LEVEL=info

# -----------------------------------------------------
# TRIAL
# -----------------------------------------------------
FREE_TRIAL_DAYS=7

# -----------------------------------------------------
# DEFAULT PLAN
# -----------------------------------------------------
DEFAULT_PLAN=starter

# -----------------------------------------------------
# ENTERPRISE EMAIL
# -----------------------------------------------------
SALES_EMAIL=sales@layboka.com

# -----------------------------------------------------
# SUPPORT EMAIL
# -----------------------------------------------------
SUPPORT_EMAIL=support@layboka.com

# ----------------------------------------
# STRIPE 
# ----------------------------------------
# STRIPE_STARTER_PRICE_ID=
# STRIPE_GROWTH_PRICE_ID=
# STRIPE_PREMIUM_PRICE_ID=
#----------------------------------------
